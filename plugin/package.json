{
  "name": "claude-streamdeck-plugin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "rollup -c",
    "watch": "rollup -c -w --watch.onEnd=\"streamdeck restart com.erbendriessen.claude\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@elgato/cli": "^1.7.0",
    "@rollup/plugin-commonjs": "^29.0.2",
