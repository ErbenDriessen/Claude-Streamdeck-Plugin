    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.1.0",
    "@tsconfig/node20": "^20.1.2",
    "@types/node": "~24.1.0",
    "rollup": "^4.0.2",
    "sharp": "^0.35.1",
    "tslib": "^2.6.2",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@elgato/streamdeck": "^2.0.0"
  }
